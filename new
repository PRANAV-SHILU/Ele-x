<!DOCTYPE html><html>
<head>
    <title>Mega Deals</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #0f0f0f;
            color: #fff;
            text-align: center;
        }
        .header {
            font-size: 40px;
            color: orange;
            margin-top: 20px;
        }
        .sub-header {
            font-size: 24px;
            margin-bottom: 20px;
        }
        .timer {
            font-size: 30px;
            color: orange;
            margin-bottom: 30px;
        }
        .products {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
        }
        .card {
            background-color: #1f1f1f;
            border-radius: 10px;
            width: 180px;
            padding: 15px;
        }
        .card img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 8px;
        }
        .discount {
            background-color: red;
            color: white;
            font-size: 14px;
            padding: 2px 5px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 10px;
        }
        .price {
            margin: 10px 0;
        }
        .price del {
            color: gray;
            margin-left: 5px;
        }
        .button {
            background-color: orange;
            border: none;
            color: black;
            padding: 10px;
            border-radius: 5px;
            cursor: pointer;
        }
        .promo {
            background-color: #222;
            color: orange;
            padding: 15px;
            margin-top: 30px;
            font-weight: bold;
        }
    </style>
</head>
